{
  "name": "finance-backend",
  "version": "1.0.0",
  "description": "Finance data processing and role-based access control backend with Express and PostgreSQL.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand",
    "lint": "eslint \"src/**/*.js\" \"tests/**/*.js\"",
    "db:migrate": "node src/db/runSqlFile.js src/db/migrations/001_schema.sql",
    "db:seed": "node src/db/runSqlFile.js src/db/migrations/002_seed.sql"
  },
  "keywords": [
    "express",
    "postgresql",
    "rbac",
    "finance"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.13.3",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0"
  }
}
