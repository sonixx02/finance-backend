{
  "openapi": "3.0.3",
  "info": {
    "title": "Finance Backend API",
    "version": "1.0.0",
    "description": "Focused v1 API surface for the finance backend assignment."
  },
  "servers": [
    {
      "url": "http://localhost:4000",
      "description": "Local development"
    }
  ],
  "tags": [
    {
      "name": "Health"
    },
    {
      "name": "Auth"
    },
    {
      "name": "Records"
    },
    {
      "name": "Dashboard"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "admin@finance.local"
          },
          "password": {
            "type": "string",
            "example": "Admin123!"
          }
        }
      },
      "RecordWriteRequest": {
        "type": "object",
        "required": ["amount", "categoryPublicId", "currencyCode", "occurredOn", "recordTypeCode"],
        "properties": {
          "amount": {
            "type": "number",
            "example": 1200
          },
          "categoryPublicId": {
            "type": "string",
            "format": "uuid",
            "example": "Use a value returned by GET /records/lookups"
          },
          "currencyCode": {
            "type": "string",
            "example": "INR"
          },
          "occurredOn": {
            "type": "string",
            "format": "date",
            "example": "2026-04-01"
          },
          "recordTypeCode": {
            "type": "string",
            "example": "income"
          },
          "notes": {
            "type": "string",
            "example": "April salary"
          }
        }
      },
      "RecordUpdateRequest": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "example": 1450
          },
          "categoryPublicId": {
            "type": "string",
            "format": "uuid"
          },
          "currencyCode": {
            "type": "string",
            "example": "INR"
          },
          "occurredOn": {
            "type": "string",
            "format": "date",
            "example": "2026-04-10"
          },
          "recordTypeCode": {
            "type": "string",
            "example": "income"
          },
          "notes": {
            "type": "string",
            "example": "Updated salary"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "message": {
            "type": "string",
            "example": "Missing required permission: records.read."
          },
          "code": {
            "type": "string",
            "example": "FORBIDDEN"
          }
        }
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Service is healthy"
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Authenticate and receive a JWT",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful"
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Inactive user"
          }
        }
      }
    },
    "/records/lookups": {
      "get": {
        "tags": ["Records"],
        "summary": "Fetch active record types and categories",
        "description": "Use this before POST or PATCH record requests because category public IDs are seed-time values.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Record lookups fetched"
          },
          "401": {
            "description": "Missing or invalid token"
          },
          "403": {
            "description": "Missing records.read permission"
          }
        }
      }
    },
    "/records": {
      "get": {
        "tags": ["Records"],
        "summary": "List records",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "recordTypeCode",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "categoryPublicId",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "createdByPublicId",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "startDate",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "endDate",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "includeDeleted",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Records fetched"
          }
        }
      },
      "post": {
        "tags": ["Records"],
        "summary": "Create a record",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecordWriteRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Record created"
          },
          "400": {
            "description": "Validation or business-rule error"
          },
          "403": {
            "description": "Missing records.create permission"
          }
        }
      }
    },
    "/records/{publicId}": {
      "get": {
        "tags": ["Records"],
        "summary": "Fetch one record",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "publicId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Record fetched"
          }
        }
      },
      "patch": {
        "tags": ["Records"],
        "summary": "Update a record",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "publicId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecordUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Record updated"
          }
        }
      },
      "delete": {
        "tags": ["Records"],
        "summary": "Soft delete a record",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "publicId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Record deleted"
          }
        }
      }
    },
    "/dashboard/summary": {
      "get": {
        "tags": ["Dashboard"],
        "summary": "Return the focused dashboard summary",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "startDate",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "endDate",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Summary fetched"
          },
          "403": {
            "description": "Missing dashboard.read permission"
          }
        }
      }
    }
  }
}
